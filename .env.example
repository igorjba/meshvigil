# MeshVigil environment.
#
# The demo runs with ZERO configuration — the simulation is fully client-side.
# These variables only enable the optional snapshot-persistence feature.

# Optional: Upstash Redis for shareable snapshots (/api/snapshot).
# Create a free database at https://upstash.com and paste the REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: surfaced by /api/health. Vercel sets VERCEL_GIT_COMMIT_SHA for you.
NEXT_PUBLIC_APP_VERSION=dev
